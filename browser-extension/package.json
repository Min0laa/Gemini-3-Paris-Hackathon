{
  "name": "youtube-studio-extension",
  "displayName": "YouTube Studio Extension",
  "version": "0.0.1",
  "description": "Extension browser qui s'ins\u00e8re dans le flux d'upload de YouTube Studio",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.90.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.258",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "manifest": {
    "host_permissions": [
      "https://studio.youtube.com/*",
      "https://www.youtube.com/*",
      "http://localhost:8001/*"
    ]
  }
}
